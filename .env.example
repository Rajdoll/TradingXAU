# .env.example — Copy to .env and fill in real values. Never commit .env.

# ── Required ────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# ── Risk Settings (override defaults from PRD §9) ───────────────
ACCOUNT_BALANCE=50.00
RISK_PCT=0.02

# ── Optional: FRED API for macro data (Phase 2) ─────────────────
# Free key at https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxx

# ── Optional: Telegram bot (Phase 3) ────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Optional: Override LLM models ───────────────────────────────
ANALYST_MODEL=claude-sonnet-4-6
LIGHT_MODEL=claude-haiku-4-5-20251001
